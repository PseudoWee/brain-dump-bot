# Get this from @BotFather on Telegram
BOT_TOKEN=

# Supabase Postgres connection string.
# Project Settings -> Database -> Connection string -> URI
# Use the "Session" pooler (port 5432/6543 direct or session mode), NOT "Transaction" mode,
# since this bot keeps a persistent connection pool.
DATABASE_URL=postgres://user:password@host:5432/postgres

# Optional: IANA timezone used to interpret reminder times you type (e.g. "tomorrow 9am").
# Defaults to UTC if not set.
TZ=UTC

# Optional: restrict the bot to your Telegram user id(s), comma separated.
# Find your id by messaging @userinfobot. Leave empty to allow anyone to use the bot.
ALLOWED_USER_IDS=

# Required for /summary. Get a free API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: which OpenRouter model to use for /summary. Defaults to an open-weight Llama model.
# Browse models (and note free ":free" variants) at https://openrouter.ai/models
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
